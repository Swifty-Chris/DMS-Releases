<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    iOS Ad-Hoc OTA Installation Manifest.

    Wird bei jedem Release durch die GitHub Action aktualisiert und zeigt
    auf die neueste .ipa-Datei.

    Installation via itms-services://?action=download-manifest&url=…manifest.plist
    (nur in Safari).
-->
<plist version="1.0">
<dict>
    <key>items</key>
    <array>
        <dict>
            <key>assets</key>
            <array>
                <dict>
                    <key>kind</key>
                    <string>software-package</string>
                    <key>url</key>
                    <string>https://github.com/Swifty-Chris/DMS-Releases/releases/latest/download/DMS.ipa</string>
                </dict>
            </array>
            <key>metadata</key>
            <dict>
                <key>bundle-identifier</key>
                <string>de.cs-training.DMS</string>
                <key>bundle-version</key>
                <string>1.2.1</string>
                <key>kind</key>
                <string>software</string>
                <key>platform-identifier</key>
                <string>com.apple.platform.iphoneos</string>
                <key>title</key>
                <string>DMS</string>
            </dict>
        </dict>
    </array>
</dict>
</plist>
